{
  "name": "vs-plugin-text-line-processor",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "1.0.0",
  "publisher": "mimocode",
  "l10n": "./l10n",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lineProcessor.process",
        "title": "%command.lineProcessor.process%"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "lineProcessor.process",
          "when": "editorTextFocus"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --out build --allow-missing-repository"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "^18.0.0",
    "@vscode/l10n-dev": "^0.0.30",
    "typescript": "^5.0.0"
  }
}